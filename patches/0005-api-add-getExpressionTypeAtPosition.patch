--- /dev/null
+++ b/internal/api/session_expressiontype_test.go
@@ -0,0 +1,126 @@
+package api
+
+import (
+	"context"
+	"strings"
+	"testing"
+
+	"github.com/microsoft/typescript-go/internal/bundled"
+	"github.com/microsoft/typescript-go/internal/lsp/lsproto"
+	"github.com/microsoft/typescript-go/internal/project"
+	"github.com/microsoft/typescript-go/internal/testutil/contentmappertest"
+	"github.com/microsoft/typescript-go/internal/testutil/projecttestutil"
+	"gotest.tools/v3/assert"
+)
+
+// TestSessionGetExpressionTypeAtPosition verifies that getExpressionTypeAtPosition resolves the
+// outermost expression starting at the given position (rather than the innermost node), that it
+// stops below yield expressions (whose own type is the unwrapped yielded value, not the operand's
+// type), and that for content-mapped files the position is interpreted in the original text and
+// mapped forward into the transformed text.
+func TestSessionGetExpressionTypeAtPosition(t *testing.T) {
+	t.Parallel()
+	if !bundled.Embedded {
+		t.Skip("bundled files are not embedded")
+	}
+	ctx := context.Background()
+
+	t.Run("ascends to the outermost expression", func(t *testing.T) {
+		t.Parallel()
+		const fileName = "/home/projects/p/src/index.ts"
+		content := `declare function compute(input: string): number;
+declare function f(): Generator<number, string, boolean>;
+export const n = compute("a");
+export function* g(): Generator<number, string, boolean> {
+	const x = yield* f();
+	return x;
+}
+`
+		files := map[string]any{
+			"/home/projects/p/tsconfig.json": `{ "compilerOptions": { "strict": true, "target": "es2020" } }`,
+			fileName:                       content,
+		}
+		projectSession, _ := projecttestutil.Setup(files)
+		defer projectSession.Close()
+		session := NewSession(projectSession, nil)
+		defer session.Close()
+
+		snapshotResp, err := session.handleUpdateSnapshot(ctx, &UpdateSnapshotParams{
+			OpenProjects: []DocumentIdentifier{{FileName: "/home/projects/p/tsconfig.json"}},
+		})
+		assert.NilError(t, err)
+		projectID := snapshotResp.Projects[0].Id
+
+		getType := func(position int) *TypeResponse {
+			t.Helper()
+			resp, err := session.handleGetExpressionTypeAtPosition(ctx, &GetTypeAtPositionParams{
+				Snapshot: snapshotResp.Snapshot,
+				Project:  projectID,
+				File:     DocumentIdentifier{FileName: fileName},
+				Position: uint32(position),
+			})
+			assert.NilError(t, err)
+			return resp
+		}
+
+		// A position at the start of `compute("a")` yields the call's result type `number`;
+		// the innermost identifier's type would be the function type `(input: string) => number`.
+		callType := getType(strings.Index(content, `compute("a")`))
+		assert.Assert(t, callType != nil)
+		assert.Equal(t, callType.IntrinsicName, "number")
+
+		// A position at the start of the `yield*` operand yields the operand's type
+		// `Generator<number, string, boolean>`; ascending to the yield expression itself would
+		// yield its unwrapped type `string`.
+		operandType := getType(strings.Index(content, "f()"))
+		assert.Assert(t, operandType != nil)
+		assert.Equal(t, operandType.IntrinsicName, "")
+		assert.Assert(t, operandType.Symbol != 0)
+	})
+
+	t.Run("maps original positions of content-mapped files", func(t *testing.T) {
+		t.Parallel()
+		const fileName = "/home/project/app.box"
+		content := `declare function compute(input: string): number;
+export const result = compute("x");
+`
+		files := map[string]any{
+			"/home/project/tsconfig.json": `{
+				"compilerOptions": { "target": "es2020", "module": "esnext", "moduleResolution": "bundler", "strict": true },
+				"contentMappers": [ { "package": "mapper", "extensions": [".box"] } ]
+			}`,
+			"/home/project/node_modules/mapper/package.json": contentmappertest.PackageJSON(contentmappertest.TransformingMapper),
+			fileName: content,
+		}
+		init, _ := projecttestutil.GetSessionInitOptions(files, &project.SessionOptions{
+			CurrentDirectory:    "/home/project",
+			DefaultLibraryPath:  bundled.LibPath(),
+			TypingsLocation:     projecttestutil.TestTypingsLocation,
+			PositionEncoding:    lsproto.PositionEncodingKindUTF8,
+			LoadExternalPlugins: true,
+		}, nil)
+		init.Spawner = contentmappertest.NewSpawner()
+		projectSession := project.NewSession(init)
+		defer projectSession.Close()
+		session := NewSession(projectSession, nil)
+		defer session.Close()
+
+		snapshotResp, err := session.handleUpdateSnapshot(ctx, &UpdateSnapshotParams{
+			OpenProjects: []DocumentIdentifier{{FileName: "/home/project/tsconfig.json"}},
+		})
+		assert.NilError(t, err)
+
+		// The mapper injects a synthesized preamble ahead of the body, so the original offset of
+		// `compute("x")` only resolves to the call if it is mapped forward into the transformed
+		// text; interpreted as a transformed-text offset it would land inside the preamble region.
+		resp, err := session.handleGetExpressionTypeAtPosition(ctx, &GetTypeAtPositionParams{
+			Snapshot: snapshotResp.Snapshot,
+			Project:  snapshotResp.Projects[0].Id,
+			File:     DocumentIdentifier{FileName: fileName},
+			Position: uint32(strings.Index(content, `compute("x")`)),
+		})
+		assert.NilError(t, err)
+		assert.Assert(t, resp != nil)
+		assert.Equal(t, resp.IntrinsicName, "number")
+	})
+}
