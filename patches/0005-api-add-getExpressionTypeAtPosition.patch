+// handleGetExpressionTypeAtPosition returns the type of the outermost expression starting at a
+// position in a file. Unlike getTypeAtPosition, which resolves the innermost node, a position at
+// the start of `foo.bar(baz)` yields the type of the whole call expression. For content-mapped
+// files the position is interpreted in the file's original text and mapped forward into the
+// transformed text the checker operates over.
+func (s *Session) handleGetExpressionTypeAtPosition(ctx context.Context, params *GetTypeAtPositionParams) (*TypeResponse, error) {
+	setup, err := s.setupChecker(ctx, params.Snapshot, params.Project)
+	if err != nil {
+		return nil, err
+	}
+	defer setup.done()
+
+	sourceFile := setup.program.GetSourceFile(params.File.ToFileName())
+	if sourceFile == nil {
+		return nil, fmt.Errorf("%w: source file not found: %v", ErrClientError, params.File)
+	}
+
+	var position int
+	if spans := sourceFile.SpanMap(); spans != nil {
+		originalOffset := ast.ComputePositionMap(sourceFile.OriginalText()).UTF16ToUTF8(int(params.Position))
+		mapped := spans.OriginalToGeneratedPositions(core.TextPos(originalOffset), spanmap.PurposeSemantic)
+		position = -1
+		for _, mp := range mapped {
+			if mp.Fidelity.IsSingleSegment() {
+				position = int(mp.Position)
+				break
+			}
+		}
+		if position < 0 {
+			return nil, nil
+		}
+	} else {
+		position = sourceFile.GetPositionMap().UTF16ToUTF8(int(params.Position))
+	}
+
+	node := astnav.GetTouchingPropertyName(sourceFile, position)
+	if node == nil || ast.IsSourceFile(node) {
+		return nil, nil
+	}
+	expr := outermostExpressionAt(node)
+	t := setup.checker.GetTypeAtLocation(expr)
+	if t == nil {
+		return nil, nil
+	}
+
+	return setup.newTypeResponse(t), nil
+}
+
+// outermostExpressionAt ascends from node through enclosing expressions that share its start
+// position, so a position at the start of `foo.bar(baz)` yields the whole call expression.
+// Ascent stops below yield expressions: the type of `yield* x` is the yielded value's unwrapped
+// type, not the type of the operand expression x that a caller asking about the start of the
+// operand is interested in.
+func outermostExpressionAt(node *ast.Node) *ast.Node {
+	expr := node
+	for parent := expr.Parent; parent != nil && parent.Pos() == expr.Pos() && ast.IsExpression(parent) && parent.Kind != ast.KindYieldExpression; parent = parent.Parent {
+		expr = parent
+	}
+	return expr
+}
+
 // handleGetTypeAtPosition returns the type at a position in a file.
 func (s *Session) handleGetTypeAtPosition(ctx context.Context, params *GetTypeAtPositionParams) (*TypeResponse, error) {
 	setup, err := s.setupChecker(ctx, params.Snapshot, params.Project)
